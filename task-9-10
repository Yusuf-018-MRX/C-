    public abstract class PetShop
    {
        protected double Energy;
        protected double Acliq;
        protected string Nickname;
        protected int Age;
        protected string Gender;
        protected double Price;
        protected int Meal_pr;
        public static int total_Meal_pr = 0;
        public static double TotalPrice = 0;
        public abstract void Eat();
        public abstract void Sleep();
        public abstract void Play();
    }
    public class Cat : PetShop
    {
        public Cat(string Nickname)
        {
            this.Nickname = Nickname;
            Energy = 50;
            Acliq = 50;
            Age = 99;
            Gender = "Male";
            Price = 999;
        }
        public override void Eat()
        {
            if (Acliq <= 70)
            {
                Console.WriteLine($"{Nickname} is Eating");
                Acliq = 100;
                Energy -= 10;//yemek yeyende adamain yuxusu gelirde dedim mence bele olmalidir ama artada biler deye + da yazdim
                //Energy += 10;
                Meal_pr++;
                total_Meal_pr++;
                Age++;
                Price += 20;
                TotalPrice += 20;
            }
            else
            {
                Console.WriteLine($"{Nickname} Ac deyil ayqa");
            }
        }
        public override void Sleep()
        {
            if (Energy >= 50)
            {
                Console.WriteLine($"{Nickname} yorğun deyildana");
                Console.WriteLine($"Energy: {Energy}");
            }
            else
            {
                Console.WriteLine($"{Nickname} Sleeping");
                Energy = 100;//day dededim yatanda tam yatarda ona giorem 100 eledim
            }
        }
        public override void Play()
        {
            if (Energy >= 50)
            {
                Console.WriteLine($"{Nickname} Playing");
                Energy -= 10;
                Acliq -= 10;

                if (Energy <= 0)
                {
                    Console.WriteLine($"{Nickname} need sleep");
                    Sleep();
                }
            }
            else
            {
                Console.WriteLine($"{Nickname} yatmalıdır.");
                Console.WriteLine($"Energy: {Energy}");
            }
        }
    }
