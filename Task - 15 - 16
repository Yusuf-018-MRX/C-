
using System;
using System.Collections.Generic;
public  class Person
{
    private Guid ID;
    private string Name;
    private string SurName;
    private int Age;
    public Person(Guid ID, string Name, string SurName, int Age)
    {
        this.ID=ID;
        this.Name=Name;
        this.SurName=SurName;
        this.Age=Age;
    }
    public virtual void ShowInfo()
    {
        Console.WriteLine($"Name: {Name}\nSurname: {SurName}\nAge: {Age}\nID: {ID}");
    }
}
public enum Position 
{
    CEO,
    Worker,
    Manager
}
public abstract class Employee : Person
{
    public Employee(Guid ID, string Name, string SurName, int Age) : base(ID, Name, SurName, Age){}
    protected double Salary;
    protected Position position;
    public override void ShowInfo()
    {
        base.ShowInfo();
        Console.WriteLine($"\nPositon: {position}\nSalary: {Salary}");
    }
}
