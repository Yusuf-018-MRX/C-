    }
}
public class Credit
{
    public Guid ID;
    public Client Client;
    public double Amount;
    public double Percent;
    public int Months;
    public Credit(Client client, double amount, double percent, int months)
    {
        ID = Guid.NewGuid();
        Client = client;
        Amount = amount;
        Percent = percent;
        Months = months;
    }
    public double CalculatePercent()
    {
        return Amount * Percent / 100;
    }
    public double Payment()
    {
        return Amount + CalculatePercent();
    }
    public void ShowCredit()
    {
        Console.WriteLine($"Credit Amount: {Amount}");
        Console.WriteLine($"Percent: {Percent}");
        Console.WriteLine($"Months: {Months}");
        Console.WriteLine($"Total Payment: {Payment()}");
    }
}
public class Bank
{
    public string Name;
    public double Budget;
    public double Profit;
    public CEO CEO;
    public List<Worker> Workers = new List<Worker>();
    public List<Manager> Managers = new List<Manager>();
    public List<Client> Clients = new List<Client>();
    public List<Credit> Credits = new List<Credit>();
    public Bank(string name, double budget)
    {
        Name = name;
        Budget = budget;
    }
    public double Calculate_Profit()
    {
        double total = 0;

        foreach (Credit credit in Credits)
        {
            total += credit.CalculatePercent();
        }
        Profit = total;
        return Profit;
    }
    public void ShowAllCredit()
    {
        foreach (Credit credit in Credits)
        {
            credit.ShowCredit();
        }
    }
    public void ShowClientCredit(string fullname)
    {
        foreach (Credit credit in Credits)
        {
            Console.WriteLine("Client Credit:");
            credit.ShowCredit();
        }
    }
    public void PayCredit(Credit credit, double money)
    {
        credit.Amount -= money;

        if (credit.Amount < 0)
            credit.Amount = 0;
    }
}















